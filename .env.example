# Server
PORT=3000

# Email (Nodemailer / Gmail SMTP)
EMAIL_FROM=alerts@yourdomain.com
EMAIL_TO=owner@yourdomain.com
EMAIL_PASS=your_gmail_app_password

# Twilio SMS
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=your_twilio_auth_token
TWILIO_FROM=+15550000000
TWILIO_TO=+15551111111

# Alert mode: "owner" sends alerts to EMAIL_TO / TWILIO_TO
#             "client" sends alerts to the individual client's email / phone
ALERT_MODE=owner

# Oxylabs Web Scraper API (optional — leave blank to use mock data)
# Sign up at https://oxylabs.io
OXYLABS_USER=your_oxylabs_username
OXYLABS_PASS=your_oxylabs_password
